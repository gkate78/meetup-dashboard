# Meetup API token
MEETUP_TOKEN=

# Optional file-backed snapshot storage
SNAPSHOT_PATH=cache/meetup_snapshot.db
SNAPSHOT_BACKEND=file
SNAPSHOT_S3_BUCKET=
SNAPSHOT_S3_KEY=meetup/meetup_snapshot.json

# Persistent runtime storage
FEEDBACK_DATA_PATH=data/feedback.db
SPEAKER_OVERRIDES_PATH=data/speaker_overrides.db
EVENT_BOOKINGS_PATH=data/event_bookings.db

# Optional cache and API tuning
DATA_TTL_SECONDS=86400
REQUEST_CONNECT_TIMEOUT=5
REQUEST_READ_TIMEOUT=30
API_MAX_RETRIES=4
API_RETRY_BASE_SECONDS=1.5

# Optional moderator access for admin booking management
ADMIN_PASSWORD=
